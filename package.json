{
  "name": "external-posture-insight-app",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:core && concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm run build:core && node server/index.mjs",
    "build:core": "tsc -p packages/core/tsconfig.json",
    "typecheck:core:strict": "tsc -p packages/core/tsconfig.strict.json",
    "typecheck:architecture:strict": "tsc -p tsconfig.architecture-strict.json",
    "build": "npm run build:core && vite build",
    "build:server": "npm run build:core",
    "build:hostinger": "rm -rf dist && VITE_API_BASE_URL=https://securl-app-production.up.railway.app npm run build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "verify": "node scripts/verify-build.mjs",
    "ship": "npm run build:hostinger && npm run verify",
    "verify:hostinger": "node scripts/verifyHostingerBuild.mjs",
    "package:hostinger": "npm run build:hostinger && npm run verify:hostinger && node scripts/packageHostingerBuild.mjs",
    "deploy:hostinger": "node scripts/deployHostinger.mjs",
    "deploy:hostinger:live": "node scripts/deployHostinger.mjs --live",
    "telemetry": "node scripts/fetchTelemetry.mjs",
    "telemetry:web": "node scripts/telemetryDashboard.mjs",
    "check:deploy": "node server/checkDeployReadiness.mjs",
    "pack:core": "npm pack --dry-run ./packages/core",
    "release:core:check": "npm run build:core && npm run typecheck:core:strict && npm run test:core && npm run lint && npm run pack:core",
    "test:core": "npm run build:core && node --test packages/core/test/*.test.mjs",
    "test:server": "npm run build && node --test server/test/*.test.mjs",
    "test:app:unit": "vitest run src/lib/*.test.ts --pool=threads --maxWorkers=1",
    "preview": "vite preview",
    "snapshot:hero-sample": "node scripts/snapshotHeroSample.mjs",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
